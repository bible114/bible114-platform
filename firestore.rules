rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isPlatformAdmin() {
      return isSignedIn() &&
        myData().role in ['platformAdmin', 'superAdmin'];
    }
    function isChurchAdmin(churchId) {
      return isSignedIn() &&
        myData().role == 'churchAdmin' &&
        myData().churchId == churchId;
    }
    function sameChurch(churchId) {
      return isSignedIn() && myData().churchId == churchId;
    }

    // 사용자 문서
    match /users/{uid} {
      allow read: if request.auth.uid == uid ||
        (isSignedIn() && isChurchAdmin(resource.data.churchId)) ||
        isPlatformAdmin();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if request.auth.uid == uid ||
        (isSignedIn() && isChurchAdmin(resource.data.churchId)) ||
        isPlatformAdmin();
      allow delete: if isPlatformAdmin() ||
        (isSignedIn() && isChurchAdmin(resource.data.churchId));

      // 읽기 기록 서브컬렉션 — 본인만 읽기/쓰기, 관리자 읽기
      match /history/{historyId} {
        allow read: if request.auth.uid == uid || isPlatformAdmin();
        allow create: if request.auth.uid == uid;
        allow delete: if isPlatformAdmin();
      }
    }

    // 교회 문서 (가입 전 교회 목록 조회 필요 → 미인증 read 허용)
    match /churches/{churchId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isChurchAdmin(churchId) || isPlatformAdmin();
      allow delete: if isPlatformAdmin();

      match /settings/{settingId} {
        allow read: if sameChurch(churchId) || isPlatformAdmin();
        allow write: if isChurchAdmin(churchId) || isPlatformAdmin();
      }
    }

    // 말씀 (verses) — 읽기 전용
    match /verses/{verseId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    // 플랫폼 집계 통계 — 미인증 공개 읽기 (로그인 페이지에서 사용)
    match /settings/platformStats {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 그 외 설정 문서
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }
  }
}
